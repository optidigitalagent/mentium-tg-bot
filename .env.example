# =============================================
# Mentium Telegram Bot — Environment Variables
# =============================================

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Webhook mode: false for Railway production, true for local dev polling
TELEGRAM_USE_POLLING=false

# Database (Railway Postgres — connect via "Add Reference" in Railway dashboard)
DATABASE_URL=

# Redis (Railway Redis — connect via "Add Reference" in Railway dashboard)
REDIS_URL=

# Platform integration
PLATFORM_FRONTEND_URL=https://aware-alignment-production.up.railway.app
PLATFORM_API_URL=https://aiteacher-production-cae8.up.railway.app
INTERNAL_TELEGRAM_API_KEY=

# Public URL of this bot service on Railway (required when TELEGRAM_USE_POLLING=false)
# Example: https://mentium-bot.up.railway.app
PUBLIC_BOT_URL=

# Bot config (do not change FIXED_LESSON_DURATION_MINUTES)
DEFAULT_TIMEZONE=Europe/Kiev
FIXED_LESSON_DURATION_MINUTES=50
DAY_OF_LESSON_OFFSET_MINUTES=180

# Server
PORT=4001
NODE_ENV=production
LOG_LEVEL=info

# Optional
SENTRY_DSN=
