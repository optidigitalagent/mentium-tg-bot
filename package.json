{
  "name": "ai-teacher-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram Habit & Retention Bot for AI Teacher platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').cpSync('src/db/migrations', 'dist/db/migrations', {recursive: true})\"",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker": "node dist/workers/workerEntry.js",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/workerEntry.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "telegram:set-webhook": "ts-node src/scripts/setWebhook.ts",
    "telegram:delete-webhook": "ts-node src/scripts/deleteWebhook.ts"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bullmq": "^5.4.2",
    "zod": "^3.22.4",
    "luxon": "^3.4.4",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.8",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
